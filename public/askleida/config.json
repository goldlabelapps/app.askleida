{
    "tenant": "askleida",
    "siteName": "Ask Leida",
    "description": "Where skin care practitioners can manage clients, products, recommendations, and advice",
    "url": "https://askleida.vercel.app/",
    "owner": {
        "name": "Millie",
        "email": "hello@askleida.com"
    },
    "favicon": "/askleida/svg/favicon.svg",
    "avatars": {
        "light": "/askleida/svg/avatarLight.svg",
        "dark": "/askleida/svg/avatarDark.svg"
    },
    "images": {
        "light": "/askleida/png/palette.png",
        "dark": "/askleida/png/palette.png"
    },
    "cartridges": {
        "paywall": {
            "provider": "supabase",
            "enabled": true
        },
        "designSystem": {
            "themeSwitching": true,
            "defaultTheme": "light",
            "themes": {
                "light": {
                    "mode": "light",
                    "primary": {
                        "main": "#5F8F87",
                        "hover": "#507972",
                        "soft": "#E6F0EE"
                    },
                    "secondary": "#364450",
                    "background": {
                        "base": "#F7F5F2",
                        "surface": "#F7F5F2",
                        "surfaceAlt": "#F7F5F2"
                    },
                    "paper": "#FFF",
                    "border": "#5F8F87",
                    "text": {
                        "primary": "#000",
                        "secondary": "#000"
                    },
                    "accent": {
                        "warm": "#C78E5B",
                        "gold": "#D8B36A",
                        "rose": "#B97C85",
                        "plum": "#5B435C"
                    },
                    "status": {
                        "success": "#4D8B68",
                        "warning": "#C08A3E",
                        "error": "#B75C5C",
                        "info": "#5B84B2"
                    }
                },
                "dark": {
                    "mode": "dark",
                    "primary": "#ffd849",
                    "secondary": "#ffd849",
                    "background": "#364450",
                    "paper": "#364450",
                    "text": "#fff"
                }
            },
            "typography": {
                "heading": [
                    "Cormorant Garamond",
                    "Fraunces"
                ],
                "body": [
                    "Cormorant Garamond",
                    "Fraunces"
                ]
            }
        }
    }
}